// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Portability rules (kept even after the SQLite -> Postgres migration, so this
// schema still works unmodified against either provider if ever needed again):
// - no Prisma `enum` -> plain String, validated with Zod at the boundary
// - no scalar list types (String[]) and no @db.* native types -> use Json instead
// - ids are @default(cuid()), never dbgenerated()

// ---------- Auth (NextAuth / Auth.js Prisma adapter) ----------

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  folders            Folder[]
  tags               Tag[]
  projects           Project[]
  articles           Article[]
  highlights         Highlight[]
  comments           Comment[]
  readingSessions    ReadingSession[]
  knowledgeNodes     KnowledgeMapNode[]
  knowledgeEdges     KnowledgeMapEdge[]
  writingDocuments   WritingDocument[]
  writingBlocks      WritingBlock[]
  savedFilters       SavedFilter[]
  goals              Goal[]
  achievements       UserAchievement[]
  engagementSettings EngagementSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Organization (per-user) ----------

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  parentId  String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Folder?   @relation("FolderChildren", fields: [parentId], references: [id])
  children Folder[]  @relation("FolderChildren")
  articles Article[]

  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles   ArticleTag[]
  highlights HighlightTag[]

  @@unique([userId, name])
}

model Project {
  id               String    @id @default(cuid())
  userId           String
  name             String
  description      String?
  objective        String?
  researchQuestion String?
  hypotheses       Json? // string[]
  keywords         Json? // string[]
  color            String?
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles         ArticleProject[]
  writingDocuments WritingDocument[]

  @@index([userId])
}

model ArticleProject {
  articleId String
  projectId String
  addedAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([articleId, projectId])
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

// Tags on a highlight represent the subject of that excerpt specifically,
// not the whole article (an article can touch many themes across its highlights).
model HighlightTag {
  highlightId String
  tagId       String

  highlight Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([highlightId, tagId])
}

// ---------- Bibliographic entities ----------
// Author/Journal are intentionally global (not userId-scoped) to dedupe across users.
// Privacy is still enforced because every query into these tables is reached
// through an Article, and Article always carries userId.

model Author {
  id             String   @id @default(cuid())
  name           String
  normalizedName String
  orcid          String?
  createdAt      DateTime @default(now())

  articles ArticleAuthor[]

  @@index([normalizedName])
}

model Journal {
  id        String   @id @default(cuid())
  name      String
  issn      String?
  publisher String?
  createdAt DateTime @default(now())

  articles Article[]
}

model ArticleAuthor {
  articleId       String
  authorId        String
  position        Int // author order, used for citation formatting
  isCorresponding Boolean @default(false)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([articleId, authorId])
}

// ---------- Core: Article + File ----------

model Article {
  id        String  @id @default(cuid())
  userId    String
  folderId  String?
  journalId String?

  title           String
  subtitle        String?
  abstractText    String?
  year            Int?
  publicationDate DateTime?
  volume          String?
  issue           String?
  pages           String?
  doi             String?
  url             String?
  language        String?
  keywords        Json? // string[]

  stage             String  @default("INBOX") // INBOX | LIBRARY
  status            String  @default("NAO_INICIADO") // NAO_INICIADO | LENDO | CONCLUIDO | ABANDONADO
  completenessScore Int     @default(0)
  favorite          Boolean @default(false)

  summaryContent   Json? // Tiptap JSON - "Resumo pessoal"
  summaryUpdatedAt DateTime?

  currentPage  Int       @default(1)
  totalPages   Int?
  lastOpenedAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder  Folder?  @relation(fields: [folderId], references: [id])
  journal Journal? @relation(fields: [journalId], references: [id])

  file              File?
  authors           ArticleAuthor[]
  tags              ArticleTag[]
  projects          ArticleProject[]
  highlights        Highlight[]
  comments          Comment[]
  readingSessions   ReadingSession[]
  processingJobs    ProcessingJob[]
  references        Reference[]       @relation("CitingArticle")
  citedByReferences Reference[]       @relation("MatchedArticle")
  knowledgeNode     KnowledgeMapNode?
  writingBlocks     WritingBlock[]

  @@index([userId, stage])
  @@index([userId, status])
}

model File {
  id               String   @id @default(cuid())
  articleId        String   @unique
  storageProvider  String   @default("local") // local | google_drive
  storageKey       String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  checksumSha256   String?
  createdAt        DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

// ---------- Background processing (DB-backed queue, no Redis/Docker needed) ----------

model ProcessingJob {
  id         String    @id @default(cuid())
  articleId  String
  type       String // EXTRACT_METADATA | CROSSREF_LOOKUP
  status     String    @default("PENDING") // PENDING | RUNNING | SUCCEEDED | FAILED
  attempts   Int       @default(0)
  lastError  String?
  payload    Json?
  result     Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

// ---------- Highlights & Comments ----------

model Highlight {
  id           String   @id @default(cuid())
  userId       String
  articleId    String
  color        String // CONCEITO_IMPORTANTE | METODOLOGIA | CITACAO | RESULTADO | CRITICA | COMENTARIO
  page         Int
  excerptText  String
  positionData Json // { pageNumber, boundingRect, rects[] } normalized 0..1
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  article       Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  comments      Comment[]
  writingBlocks WritingBlock[]
  tags          HighlightTag[]

  @@index([articleId, color])
}

model Comment {
  id          String   @id @default(cuid())
  userId      String
  articleId   String
  highlightId String? // null = general article comment, set = highlight-anchored
  body        Json // Tiptap JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  article       Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  highlight     Highlight?     @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  writingBlocks WritingBlock[]

  @@index([articleId])
}

// ---------- Reading analytics (write-path now, dashboard UI is Phase 2) ----------

model ReadingSession {
  id              String    @id @default(cuid())
  userId          String
  articleId       String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  startPage       Int?
  endPage         Int?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([userId, articleId])
}

// ---------- Citations extracted from the article body (schema-only in Phase 1) ----------

model Reference {
  id               String   @id @default(cuid())
  citingArticleId  String
  rawText          String
  parsedTitle      String?
  parsedAuthors    Json?
  parsedYear       Int?
  doi              String?
  matchedArticleId String?
  createdAt        DateTime @default(now())

  citingArticle  Article  @relation("CitingArticle", fields: [citingArticleId], references: [id], onDelete: Cascade)
  matchedArticle Article? @relation("MatchedArticle", fields: [matchedArticleId], references: [id])
}

// ---------- Knowledge Map (schema-only in Phase 1; graph UI is Phase 2) ----------

model KnowledgeMapNode {
  id        String   @id @default(cuid())
  userId    String
  articleId String   @unique
  x         Float?
  y         Float?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  outgoing KnowledgeMapEdge[] @relation("SourceNode")
  incoming KnowledgeMapEdge[] @relation("TargetNode")
}

model KnowledgeMapEdge {
  id             String   @id @default(cuid())
  userId         String
  sourceNodeId   String
  targetNodeId   String
  connectionType String // COMPLEMENTA | CONTRADIZ | APROFUNDA | BASE_TEORICA | METODOLOGIA_SEMELHANTE | MESMO_ESTUDO_DE_CASO
  origin         String   @default("MANUAL") // MANUAL | AUTO
  note           String?
  createdAt      DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  source KnowledgeMapNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  target KnowledgeMapNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, connectionType])
}

// ---------- Painel de Escrita (writing workspace) ----------

model WritingDocument {
  id        String   @id @default(cuid())
  userId    String
  title     String
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?       @relation(fields: [projectId], references: [id])
  blocks  WritingBlock[]

  @@index([userId])
}

model WritingBlock {
  id          String   @id @default(cuid())
  documentId  String
  userId      String
  order       Int
  blockType   String // TEXT | HIGHLIGHT_REF | COMMENT_REF | SUMMARY_REF | CITATION_REF
  textContent String? // plain text, only for TEXT blocks
  articleId   String? // source article, for *_REF blocks
  highlightId String? // for HIGHLIGHT_REF blocks
  commentId   String? // for COMMENT_REF blocks
  createdAt   DateTime @default(now())

  document  WritingDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article?        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  highlight Highlight?      @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  comment   Comment?        @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([documentId, order])
}

// A favorited combination of Knowledge Base search filters (including tag selection),
// so users revisiting the same research question don't have to re-set every field.
model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json // serialized HighlightSearchFilters
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Engajamento (reading habits, personal goals, achievements) ----------

model Goal {
  id        String    @id @default(cuid())
  userId    String
  type      String // ARTICLES | PAGES | TIME | HIGHLIGHTS | WRITING
  metric    String // ARTICLES_COMPLETED | PAGES_READ | TIME_MINUTES | HIGHLIGHTS_CREATED | WRITING_CITATIONS | WRITING_DOCUMENTS
  frequency String // DAILY | WEEKLY | MONTHLY
  target    Int
  active    Boolean   @default(true)
  pausedAt  DateTime?
  startDate DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

// One row per badge the user has unlocked — badge definitions themselves live in
// code (modules/engagement/domain/entities.ts), not the database.
model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  badgeKey   String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
}

// One row per user — created on demand (get-or-create) the first time settings are read.
model EngagementSettings {
  id                   String    @id @default(cuid())
  userId               String    @unique
  gamificationEnabled  Boolean   @default(true)
  showBadges           Boolean   @default(true)
  remindersEnabled     Boolean   @default(true)
  enabledReminderTypes Json      @default("[\"STALLED_ARTICLE\",\"ALMOST_DONE\",\"DAILY_GOAL\",\"INBOX_PENDING\"]")
  reminderDays         Json      @default("[]") // [] = every day; else array of "MON".."SUN"
  reminderTime         String? // "HH:mm" — reminders only show from this hour onward
  dailyGoalMinutes     Int?
  weeklyGoalMinutes    Int?
  monthlyGoalMinutes   Int?
  pausedUntil          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
